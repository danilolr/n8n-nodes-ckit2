{
    "name": "@chatbot-kit/n8n-nodes-ckit2",
    "version": "0.1.6",
    "description": "Next-generation Chatbot Kit nodes for n8n",
    "main": "dist/nodes/CKit2/CKit2.node.js",
    "license": "MIT",
    "homepage": "https://github.com/danilolr/n8n-nodes-ckit2#readme",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "chatbot-kit",
        "chatbot"
    ],
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "Danilo Luiz Rheinheimer",
        "email": "danilolr@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/danilolr/n8n-nodes-ckit2.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev:prepare": "./scripts/prepare-dev-package.sh",
        "dev": "npm run build && npm run dev:prepare && npm run build:watch",
        "dev:n8n": "./scripts/dev-n8n.sh",
        "dev:n8n:debug": "N8N_DEBUG_PORT=9240 ./scripts/dev-n8n.sh",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "node -e \"if (!process.env.CI) { console.error('Publish via GitHub Actions only. Use npm run release locally to create the tag and GitHub release.'); process.exit(1); }\""
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [],
        "nodes": [
            "dist/nodes/CKit2/CKit2.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "0.23.1",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
